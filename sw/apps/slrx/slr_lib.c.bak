void slr_animate_hook(char * ds_test_file_path) {

  #ifdef ANIMATE
  
  static char is_first_call = TRUE ; 
  
  char class_str[60] ;
  #ifndef _GP_VAL_
  bm_sprintf(class_str,"GifPlayer()"); // will take default $SLR_SHARED/pt/workspace//seq_output.gif
  #else     
  //bm_sprintf(class_str,"GifPlayer("\"t0/%s.gif\")",EXPAND_AND_STRINGIFY(_GP_VAL_));  
  bm_sprintf(class_str,"GifPlayer('t0/%s.gif')",EXPAND_AND_STRINGIFY(_GP_VAL_));    
  #endif
  

  if (is_first_call) bm_pyshell_get_class_obj("$SLR_SHARED/text_to_slr", // path_str
                                              "play_gif",                // module_name
                                              class_str,                 // class_str 
                                              "gp") ;                    // obj_name
 
   // Provide pattern name   
    bm_pyshell_exec ("gp.next_frame()");        
 
  
  is_first_call = FALSE ;

  #endif  
}

//-----------------------------------------------------------------------------------------------------------

char loop_speed_test_on(infer_cb_t             infer_cb,
                        slr_ds_image_t*        slr_ds_imgs,
                        slr_model_params_t*    slr_model_params_p,
                        slr_intr_fm_t*         slr_intr_fm_p) {
   
  #ifndef LST 
  return FALSE ;
  #else
  int num_img_words = IMG_DIM*IMG_DIM/4 ;
  for (int i=0;i<num_img_words;i++) ((int *)(slr_ds_imgs[0].slr_img))[i] = 0 ;
  
 
  int sys_clk_mhz = bm_get_sys_clk_mhz();

  #ifndef NUM_LST_ITR  
  #define NUM_LST_ITR 50000 
  #endif
  
  printf("Running image in loop for %d iteration at FPGA configured rate %d MHz\n", NUM_LST_ITR, sys_clk_mhz);
  printf("Watch actual wall time on FPGA board display\n");
 

  static int start_cycle,end_cycle ;     // For performance checking.  
  static long long int ll_acc_diff;      // Need to accumulate in case exceeding 32 bits
  
 unsigned int cyc_per_sec = sys_clk_mhz*1000000 ; // Per configured board clock rate
 unsigned int cyc_per_10ms = cyc_per_sec/100 ;  
 
 static unsigned int num_10ms = 0 ;  
 static unsigned int disp7s_cyc_acc = 0 ;
  
 
  ll_acc_diff = 0 ;                      // Need to accumulate in case exceeding 32 bits
  ENABLE_CYCLE_COUNT ;                   // Enable the cycle counter
  RESET_CYCLE_COUNT  ;                   // Reset counter to ensure 32 bit counter does not wrap in-between start and end.   
  GET_CYCLE_COUNT_START(start_cycle) ;   // Capture the cycle count before the operation. 
  
    
  for (int itr=0; itr<NUM_LST_ITR; itr++) { 
  
          
    int detected_label_id = infer_cb(slr_ds_imgs[0].slr_img, // inferred image 
                                     slr_model_params_p,     // model parameters
                                     slr_intr_fm_p,          // interm feature-maps memory space
                                     FALSE,                  // enable performance check
                                     itr);                   // running image index
          

     GET_CYCLE_COUNT_END(end_cycle);           // Capture after iteration.
     unsigned int uint_cyc_diff = end_cycle-start_cycle ; 
     ll_acc_diff += (long long int)(uint_cyc_diff); // Accumulate across iterations
     RESET_CYCLE_COUNT  ;                           // Avoid 32 bit wrap around
     GET_CYCLE_COUNT_START(start_cycle) ;           // Capture the cycle count before the operation.
      

     
     disp7s_cyc_acc += uint_cyc_diff ;
     
     if (disp7s_cyc_acc >= cyc_per_10ms) {  
     
       num_10ms += disp7s_cyc_acc/cyc_per_10ms ; // round
       disp7s_cyc_acc = disp7s_cyc_acc % cyc_per_10ms ; // update to reminder
       display_6dig_7seg_sec_p2f(num_10ms) ;  
     }
  
  } // for

  // Report
  char ll_val_str[40] ;// Long-Long-Int to string (long long not supported by bm_printf)
  bm_format_with_commas(ll_acc_diff, ll_val_str);    
  bm_printf("\n\nMeasured %s K5 cycles for %d images\n\n",ll_val_str,NUM_LST_ITR); 
  bm_printf("Average of %d cycles per image\n\n",(int)(ll_acc_diff/NUM_LST_ITR)); 
  bm_printf("%d ms for %d images\n\n",num_10ms*10,NUM_LST_ITR); 
  bm_printf("Average %.3f ms per image\n\n",(float)num_10ms*10/NUM_LST_ITR); 

  return TRUE ; 
  #endif
    
}

