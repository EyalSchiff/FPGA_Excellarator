void get_ds_test_file_path(char * ds_test_file_path) {
      
          #ifndef _GP_VAL_
          bm_sprintf(ds_test_file_path,"%s","$SLR_SHARED/pt/workspace/slr_ds_mnx.txt"); 
          #else
          bm_sprintf(ds_test_file_path,"%s_ds_mnx.txt",EXPAND_AND_STRINGIFY(_GP_VAL_));  // Locally at thread run folder #MY_K5_PROJ/run/t0   
          #endif
}       

